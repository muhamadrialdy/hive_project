# Copy to .env and edit. .env is gitignored.

# ── Server bind ──
# Used by `python main.py` (which calls uvicorn programmatically).
HOST=127.0.0.1
PORT=8088

# ── CORS ──
# Comma-separated list of origins allowed to call the API.
# Use "*" to allow any origin (development only — do not ship with this).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── JWT signing ──
# CHANGE THIS for any non-local deployment. Generate a strong value with:
#   python -c 'import secrets; print(secrets.token_urlsafe(48))'
# A leaked SECRET_KEY means anyone can forge valid login tokens.
SECRET_KEY=hive-dev-only-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Persistence ──
# SQLAlchemy URL. Default is a SQLite file in CWD. In Docker we mount a volume
# at /app/data-persist/ and use sqlite:////app/data-persist/hive.db.
DATABASE_URL=sqlite:///./hive.db

# ── Redis cache ──
# Empty value disables caching (app still works, just recomputes every time).
# In Docker the compose network resolves "redis" to the redis service.
REDIS_URL=

# ── Google Gemini ──
# Optional bootstrap value for the chat agent. The in-app Settings tab
# overrides this — see app/api/endpoints/admin.py.
GEMINI_API_KEY=
