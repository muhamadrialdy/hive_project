# Copy to .env and edit. .env is gitignored.
#
# Vite only exposes VITE_-prefixed env vars to client code, so we follow that
# convention here too (vite.config.ts reads VITE_PORT via loadEnv at startup).

# Vite dev server port. If you change this, also add the new origin to
# CORS_ORIGINS in the backend .env (root of hive_project/).
VITE_PORT=5173

# Base URL the SPA uses for backend calls. Must include the /api suffix.
VITE_API_URL=http://127.0.0.1:8088/api
